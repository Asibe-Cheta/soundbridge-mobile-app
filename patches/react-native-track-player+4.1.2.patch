+                        }
+                    }
+                }
+            }
+        }
+
+        scope.launch {
+            event.onTimedMetadata.collect {
+                val data = MetadataAdapter.fromMetadata(it)
+                val bundle = Bundle().apply {
+                    putParcelableArrayList(METADATA_PAYLOAD_KEY, ArrayList(data))
+                }
