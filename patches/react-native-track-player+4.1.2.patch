+                }
+            }
+        }
+
+        scope.launch {
+            event.playbackError.collect {
+                emit(MusicEvents.PLAYBACK_ERROR, getPlaybackErrorBundle())
+            }
+        }
+    }
+
+    private fun getPlaybackErrorBundle(): Bundle {
