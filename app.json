{
  "expo": {
    "name": "SoundBridge",
    "slug": "soundbridge-mobile",
    "version": "1.5.0",
    "orientation": "portrait",
    "icon": "./assets/images/logos/sb-app-icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "updates": {
      "url": "https://u.expo.dev/96a15afd-b1fd-4031-a790-2701fa0bffdf",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.soundbridge.mobile",
      "buildNumber": "87",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "SoundBridge needs access to your microphone for live audio sessions, voice recording, and communication.",
        "NSCameraUsageDescription": "SoundBridge needs access to your camera to upload profile pictures and post images.",
        "NSPhotoLibraryUsageDescription": "SoundBridge needs access to your photo library to upload images for posts and profile pictures.",
        "NSPhotoLibraryAddUsageDescription": "SoundBridge needs permission to save images to your photo library.",
        "NSFaceIDUsageDescription": "SoundBridge uses Face ID or Touch ID to securely log you in without typing your password."
      },
      "associatedDomains": [
        "applinks:soundbridge.live",
        "applinks:www.soundbridge.live"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logos/logo-foreground.png",
        "backgroundImage": "./assets/images/logos/logo-background.png"
      },
      "package": "com.soundbridge.mobile",
      "versionCode": 43,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "soundbridge.live",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.soundbridge.live",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "soundbridge"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "scheme": "soundbridge",
    "extra": {
      "eas": {
        "projectId": "96a15afd-b1fd-4031-a790-2701fa0bffdf"
      }
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "kotlinVersion": "2.1.20"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SoundBridge needs access to your photos to upload images for posts and profile pictures.",
          "cameraPermission": "SoundBridge needs access to your camera to take photos for posts and profile pictures."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#EC4899"
        }
      ],
      "expo-font",
      "expo-apple-authentication",
      "expo-asset",
      "expo-audio",
      "./plugins/withTrackPlayerFix"
    ]
  }
}
